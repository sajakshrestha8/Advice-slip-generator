#!/bin/bash

npm test

# Run lint - only fail on errors, ignore warnings
echo "Running linter..."
npm run lint
if [ $? -ne 0 ]; then
  echo "Linting errors found. Please fix them before committing."
  exit 1
fi
echo "Linting passed"

# Check for console.log statements
echo "Checking for console.log statements..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|js)$")

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check"
  exit 0
fi

FOUND=0

FOUND=0

for file in $STAGED_FILES; do
  if git diff --cached -- "$file" | grep "^\+" | grep -v "^\+\+" | grep -q "console\.log"; then
    echo "Found console.log in: $file"
    FOUND=1
  fi
done

echo "No console.log statements found"
exit 0
